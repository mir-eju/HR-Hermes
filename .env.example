# Copy to .env at the repository root and fill in values.

# Firebase / Firestore
FIREBASE_PROJECT_ID=
FIREBASE_SERVICE_ACCOUNT_PATH=

# 32-byte AES key: 64 hex chars OR base64 encoding of 32 raw bytes
ENCRYPTION_KEY=

# Slack: guardrail verifies requests to /slack/events (omit if Telegram-only for now)
SLACK_SIGNING_SECRET=

# Telegram: guardrail verifies X-Telegram-Bot-Api-Secret-Token on /telegram/webhook (omit if Slack-only)
TELEGRAM_WEBHOOK_SECRET=

# OpenRouter (Hermes main model — also set in ~/.hermes/.env if you use a separate Hermes home)
OPENROUTER_API_KEY=

# Optional: direct Anthropic API (only if you use Hermes with Anthropic instead of OpenRouter)
# ANTHROPIC_API_KEY=

# Guardrail HTTP server
GUARDRAIL_PORT=8787

# Logging
LOG_LEVEL=info

# Repo root for Hermes MCP subprocess paths (must be absolute in practice)
HR_HERMES_ROOT=

# Optional: global dry-run for Gmail send (still consumes approval tokens)
DRY_RUN=false

# Optional: enable learning loop in reflect-on-edits skill (project-level flag also exists)
LEARNING_ENABLED=false

# Composio (Gmail MCP: connect inbox in Composio dashboard, then set per-project composioUserId via admin)
COMPOSIO_API_KEY=

# Optional: IANA timezone for “today” in Gmail list query (is:unread after:…). If unset, uses the process local date.
# GMAIL_POLL_TZ=Asia/Dhaka

# Gmail list scope for unread poll (composio-gmail-mcp): rolling1d (default), calendar (after: today), rolling7d, none
# GMAIL_LIST_UNREAD_SCOPE=calendar
