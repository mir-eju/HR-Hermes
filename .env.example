# Copy to .env at the repository root and fill in values.

# Firebase / Firestore
FIREBASE_PROJECT_ID=
FIREBASE_SERVICE_ACCOUNT_PATH=

# 32-byte AES key: 64 hex chars OR base64 encoding of 32 raw bytes
ENCRYPTION_KEY=

# Slack app (guardrail signature verification + bot for slack-mcp)
SLACK_SIGNING_SECRET=

# Anthropic (Hermes)
ANTHROPIC_API_KEY=

# Guardrail HTTP server
GUARDRAIL_PORT=8787

# Logging
LOG_LEVEL=info

# Repo root for Hermes MCP subprocess paths (must be absolute in practice)
HR_HERMES_ROOT=

# Optional: global dry-run for Gmail send (still consumes approval tokens)
DRY_RUN=false

# Optional: enable learning loop in reflect-on-edits skill (project-level flag also exists)
LEARNING_ENABLED=false

# Gmail OAuth (used by `npm run admin -- add-project`)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://127.0.0.1:3333/oauth2callback
